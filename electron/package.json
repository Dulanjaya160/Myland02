{
  "name": "myland-desktop",
  "version": "1.0.0",
  "description": "Myland Food Management System - Desktop Application",
  "main": "main.js",
  "author": "Myland",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:win32": "electron-builder --win --ia32",
    "build:all": "electron-builder --win --x64 --ia32"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.myland.foodmanagement",
    "productName": "Myland Food Management",
    "copyright": "Copyright © 2026 Myland",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "resources/backend.jar",
        "to": "backend.jar"
      },
      {
        "from": "resources/jre",
        "to": "jre"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Myland Food Management",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": true,
      "displayLanguageSelector": false
    },
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      "resources/**/*"
    ]
  }
}